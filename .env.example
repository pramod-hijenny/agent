# ─── Frontend (.env) — Vite browser vars ONLY ────────────────────────────────
# These are bundled into the public browser build, so they must NOT be secret.
VITE_INSFORGE_URL=https://mep6b952.us-east.insforge.app
VITE_INSFORGE_ANON_KEY=<your InsForge anon JWT>

# ─── LLM / Nebius credentials are NOT in .env ────────────────────────────────
# The agent logic runs in InsForge Deno edge functions, which read config via
# Deno.env.get(...) → InsForge *function secrets*, not this file. A key placed
# here would either leak to the browser (VITE_ prefix) or never reach the
# functions. Set these with the CLI instead:
#
#   npx @insforge/cli secrets add  NEBIUS_API_KEY        "<your nebius key>"
#   npx @insforge/cli secrets update OPENAI_API_KEY      --value "<your nebius key>"
#   npx @insforge/cli secrets update OPENAI_BASE_URL     --value "https://api.tokenfactory.us-central1.nebius.com/v1/"
#   npx @insforge/cli secrets update OPENAI_MODEL        --value "moonshotai/Kimi-K2.6"
#   npx @insforge/cli secrets add  OPENAI_EMBED_BASE_URL "https://api.tokenfactory.nebius.com/v1/"
#   npx @insforge/cli secrets add  OPENAI_EMBED_MODEL    "Qwen/Qwen3-Embedding-8B"
#
# Chat (draft + screen) → Nebius us-central1 / Kimi-K2.6.
# Embeddings (discovery) → Nebius non-region host / Qwen3-Embedding-8B (4096-dim).
# View with:  npx @insforge/cli secrets list
